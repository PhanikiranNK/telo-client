{
  "expo": {
    "name": "Telo",
    "slug": "telo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-telo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app-telo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.telo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/telo.png",
        "backgroundImage": "./assets/telo.png",
        "monochromeImage": "./assets/telo.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.telo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio"
    ]
  }
}